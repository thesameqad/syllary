{
  "name": "syllary",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@10.33.4",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "pnpm -r --parallel run dev",
    "build": "pnpm --filter @syllary/web --filter @syllary/api run build",
    "typecheck": "pnpm -r run typecheck",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "db:generate": "pnpm --filter @syllary/api run db:generate",
    "db:migrate": "pnpm --filter @syllary/api run db:migrate",
    "db:push": "pnpm --filter @syllary/api run db:push",
    "db:studio": "pnpm --filter @syllary/api run db:studio"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild", "ffmpeg-static"]
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "eslint": "^9.17.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.16",
    "globals": "^15.14.0",
    "prettier": "^3.4.2",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.18.1"
  }
}
