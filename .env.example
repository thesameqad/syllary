# =============================================================================
# Syllary — environment variables
# Copy to `.env` and fill in. Never commit the real `.env`.
# VITE_* keys are exposed to the browser (frontend). Everything else is
# server-only and must never be sent to the client.
# =============================================================================

# ---- Runtime ----------------------------------------------------------------
NODE_ENV=development
# Port the Fastify API listens on
PORT=3000
LOG_LEVEL=info
# Public URL of the deployed app (used for share links, CORS, email links)
APP_URL=http://localhost:5173

# ---- Database (Supabase Postgres + Drizzle) ---------------------------------
# Supabase Dashboard -> Project Settings -> Database -> Connection string.
# Use the SESSION POOLER (port 5432) for the persistent Fastify server: it keeps
# prepared statements working and is IPv4-compatible. Supabase enforces TLS, so
# keep ?sslmode=require on the URL.
#   postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres?sslmode=require
# (If you ever run the API serverless, use the TRANSACTION pooler on port 6543
#  and set `prepare: false` in the postgres.js client — see src/db/client.ts.)
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.rsgjlailtryuvyzvehlw.supabase.co:5432/postgres
#
# Local dev alternative (Docker Postgres, no SSL):
# DATABASE_URL=postgres://postgres:postgres@localhost:5432/syllary

# ---- Auth (Clerk) -----------------------------------------------------------
# Create an app at https://dashboard.clerk.com, enable Email + Google sign-in,
# then copy the keys. CLERK_SECRET_KEY is server-only; the VITE_ one is public.
CLERK_SECRET_KEY=sk_test_xxx
VITE_CLERK_PUBLISHABLE_KEY=pk_test_xxx

# Salt for hashing IP+UA of anonymous users (1 song/day limit). Server-only.
# Generate with: openssl rand -base64 32
IP_HASH_SALT=

# Anonymous free songs allowed per UTC day. Defaults to 1; raise for testing.
ANONYMOUS_DAILY_LIMIT=1

# ---- Stripe -----------------------------------------------------------------
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
# Price IDs (create products in Stripe; all money in cents)
STRIPE_PRICE_STARTER_MONTHLY=price_xxx
STRIPE_PRICE_STARTER_YEARLY=price_xxx
STRIPE_PRICE_CREATOR_MONTHLY=price_xxx
STRIPE_PRICE_CREATOR_YEARLY=price_xxx
STRIPE_PRICE_PRO_MONTHLY=price_xxx
STRIPE_PRICE_PRO_YEARLY=price_xxx

# ---- Email (Resend) ---------------------------------------------------------
RESEND_API_KEY=re_xxx
EMAIL_FROM="Syllary <hello@syllary.com>"

# ---- File storage (Cloudflare R2, S3-compatible) ----------------------------
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=syllary-uploads
# S3 API endpoint, e.g. https://<accountid>.r2.cloudflarestorage.com
R2_ENDPOINT=
# Public base URL for served files (custom domain or r2.dev URL)
R2_PUBLIC_URL=

# ---- Vocal isolation (Replicate Demucs) -------------------------------------
REPLICATE_API_TOKEN=r8_xxx

# ---- Transcription (fal.ai → ElevenLabs Scribe v2) --------------------------
# Get a key at https://fal.ai/dashboard/keys. Scribe catches repeated chorus
# lines that Whisper drops, and returns per-word timestamps for karaoke sync.
FAL_AI_KEY=
# Cheap image model (fal.ai) for AI album covers. Default is FLUX schnell
# (~$0.003/image). Override to fal-ai/flux/dev for higher quality.
FAL_IMAGE_MODEL=fal-ai/flux/schnell

# ---- LLM cleanup + section labels (OpenRouter -> Gemini 2.5 Flash) ----------
OPENROUTER_API_KEY=sk-or-xxx
OPENROUTER_MODEL=google/gemini-2.5-flash

# ---- Spotify Web API (optional) — "Find links" track search -----------------
# Create a free app at https://developer.spotify.com/dashboard (no redirect URI
# needed; uses client-credentials). Without these, link auto-fill falls back to
# iTunes search, which can't surface Spotify links.
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# =============================================================================
# Frontend (Vite) — exposed to the browser. Prefix with VITE_.
# =============================================================================
VITE_API_URL=http://localhost:3000
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
# Plausible (self-hosted) analytics
VITE_PLAUSIBLE_DOMAIN=syllary.com
VITE_PLAUSIBLE_API_HOST=https://plausible.syllary.com
# Rewardful affiliate program (public key)
VITE_REWARDFUL_API_KEY=
